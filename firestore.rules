rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global function to verify authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the requesting user is an admin
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Check if the requesting user is a super admin
    function isSuperAdmin() {
      return isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    // `users` collection: Users can only read and write their own document.
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // `reports` collection: Users can only read and write documents where the 'uid' field matches their own.
    // Admins can list/count reports (metadata only).
    match /reports/{reportId} {
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
    }

    // `predictions` collection: Users can only read and write documents where the 'uid' field matches their own.
    // Admins can list/count predictions (metadata only).
    match /predictions/{predictionId} {
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
    }

    // `activityLogs` collection: Any authenticated user can create logs.
    // Only admins can read logs.
    match /activityLogs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    // `admins` collection: Used for security rule checks.
    // Users can create their own entry (for super admin initialization).
    // Admins can read all entries.
    // Only super admin can update/delete entries.
    match /admins/{uid} {
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow update, delete: if isSuperAdmin();
    }
  }
}
